# ── Living Master — Backend Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic (Claude) — for RAG Q&A, book generation, movement analysis
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — for text embeddings (text-embedding-3-small)
# Get at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional but recommended ──────────────────────────────────────────────────

# Serper.dev — for web discovery search (free tier: 2,500 queries/month)
# Get at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# YouTube Data API v3 — for YouTube search & channel listing
# Get at: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ElevenLabs — for high-quality voice cloning (free tier: 10k chars/month)
# Get at: https://elevenlabs.io
# If not set, the app uses free Microsoft Edge TTS voices instead.
ELEVENLABS_API_KEY=

# HuggingFace — required for speaker diarization (identifying who is speaking)
# Get at: https://huggingface.co/settings/tokens
# Also requires accepting terms at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=

# ── App settings ──────────────────────────────────────────────────────────────

APP_ENV=development
# In production, set to the URL(s) your frontend is hosted at (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Simple shared access token — change this to a random secure string in production
# In development this is not enforced (APP_ENV=development skips auth)
ACCESS_TOKEN=change_this_to_a_secure_token

# ── Model settings (optional overrides) ──────────────────────────────────────

# Whisper transcription model: tiny | base | small | medium | large
# "base" is a good default. Use "small" for better accuracy on accented speech.
WHISPER_MODEL=base

# Max file upload size in MB (default 500)
MAX_UPLOAD_MB=500

# Claude model for book/topic generation
CLAUDE_MODEL=claude-sonnet-4-6

# Claude model for chat/Q&A (cheaper model is fine here)
CHAT_MODEL=claude-haiku-4-5-20251001

# ── Persistent storage (Railway) ────────────────────────────────────────────
# In Railway: set to /data and mount a Railway volume at /data
# Locally: leave unset (defaults to the backend directory)
# DATA_DIR=/data
